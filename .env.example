# Server Setup
PORT=5000
NODE_ENV=development

# Database Setup (Postgres via Docker or RDS)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roadassist?schema=public"

# Cache & Socket.io Adapter (Redis via Docker or Managed)
REDIS_URL="redis://localhost:6379"

# Security
JWT_SECRET="roadassist_jwt_secret_key_change_me_in_prod"
JWT_EXPIRES_IN="7d"

# Payment gateway (Razorpay - Mocking enabled by default)
RAZORPAY_KEY_ID="rzp_test_mock_id"
RAZORPAY_KEY_SECRET="rzp_test_mock_secret"

# SMS/OTP gateway (Twilio - Mocking enabled if values are AC_mock_...)
TWILIO_ACCOUNT_SID="AC_mock_twilio_sid"
TWILIO_AUTH_TOKEN="mock_twilio_auth_token"
TWILIO_PHONE_NUMBER="+15556667777"

# Map Keys
GOOGLE_MAPS_API_KEY=""

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_NAME="roadassist-assets"
